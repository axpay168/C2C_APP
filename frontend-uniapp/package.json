{
  "name": "old-frontend-uniapp",
  "version": "1.0.0",
  "private": true,
  "description": "old 專案 uni-app 前端，可靜態獨立運行、不依賴 HBuilderX",
  "scripts": {
    "postinstall": "patch-package",
    "prestart": "fuser -k 8082/tcp 2>/dev/null || true",
    "start": "serve static-h5 -l 8082 -n",
    "start:static": "serve static-h5 -l 8082 -n",
    "static": "serve static-h5 -l 8082 -n",
    "dev": "npm run preview:prod:8083",
    "preview:prod:8083": "npm run sync:preview && serve preview-prod -l 8083 -n",
    "sync:preview": "rm -rf preview-prod/h5 && mkdir -p preview-prod/h5 && cp -r static-h5/* preview-prod/h5/",
    "sync:from-prod": "cp -r ../backend-php/public/h5/* static-h5/ 2>/dev/null || true",
    "build:h5": "cross-env NODE_ENV=production UNI_PLATFORM=h5 UNI_CLI_CONTEXT=$(pwd) UNI_INPUT_DIR=$(pwd) vue-cli-service build",
    "serve:dist": "serve unpackage/dist/build/h5 -l 8082",
    "deploy:h5": "cp -r unpackage/dist/build/h5/* ../backend-php/public/h5/ 2>/dev/null || cp -r static-h5/* ../backend-php/public/h5/ 2>/dev/null || echo '請先 npm run build:h5 或使用 static-h5'"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "ethers": "^6.16.0",
    "tronweb": "^6.2.2",
    "vue-i18n": "^8.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-numeric-separator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.29.0",
    "@dcloudio/uni-app": "2.0.2-4080720251210002",
    "@dcloudio/uni-cli-i18n": "2.0.2-4080720251210002",
    "@dcloudio/uni-cli-shared": "2.0.2-4080720251210002",
    "@dcloudio/uni-h5": "2.0.2-4080720251210002",
    "@dcloudio/uni-i18n": "2.0.2-4080720251210002",
    "@dcloudio/uni-migration": "2.0.2-4080720251210002",
    "@dcloudio/uni-template-compiler": "2.0.2-4080720251210002",
    "@dcloudio/vue-cli-plugin-uni": "2.0.2-4080720251210002",
    "@dcloudio/webpack-uni-pages-loader": "2.0.2-4080720251210002",
    "@vue/cli-plugin-babel": "^4.5.19",
    "@vue/cli-service": "^4.5.0",
    "autoprefixer": "^9.8.8",
    "babel-loader": "^8.4.1",
    "cache-loader": "^4.1.0",
    "copy-webpack-plugin": "^6.4.1",
    "cross-env": "^7.0.3",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^4.5.2",
    "mini-css-extract-plugin": "^0.12.0",
    "optimize-css-assets-webpack-plugin": "^5.0.8",
    "patch-package": "^8.0.1",
    "sass": "^1.32.0",
    "sass-loader": "^10.0.0",
    "serve": "^14.2.6",
    "url-loader": "^4.1.1",
    "vue": "2.6.14",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "2.6.14"
  }
}
